process {
  executor = 'pbs'
  queue    = 'long'

  /*
   * Critical on many PBS/Torque systems:
   * export the environment from the submitting job (PATH, NXF_* vars, etc.)
   */
  clusterOptions = '-V'

  /*
   * Ensure the 'module' command exists and Singularity is loaded on the compute node.
   */
  beforeScript = '''
    source /etc/profile || true
    source /etc/profile.d/modules.sh || true
    source /etc/profile.d/lmod.sh || true
    module load singularity || true
  '''

  // vcftools segfaults on TsTv-by-count for joint germline VCFs (exit 139)
  // Let the pipeline continue anyway.
  withName: /.*VCF_QC_BCFTOOLS_VCFTOOLS:VCFTOOLS_.*/ {
    errorStrategy = 'ignore'
    maxRetries    = 0
  }

}

executor {
  queueSize = 50
}

singularity {
  enabled    = true
  autoMounts = true
  // cacheDir can be set here too, but exporting NXF_SINGULARITY_CACHEDIR via -V is enough
}