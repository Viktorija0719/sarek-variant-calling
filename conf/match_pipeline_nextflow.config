params {
    // Match pipeline_nextflow.txt small-variant logic
    deepvariant_enable = true
    strelka_enable     = true

    // Make DeepVariant use WES model
    wes = true

    // Important:
    // This disables interval scattering and makes DeepVariant run once
    // per sample using the full prepared BED.
    no_intervals = true

    // Match:
    // --postprocess_variants_extra_args=only_keep_pass=true
    deepvariant_args = '--postprocess_variants_extra_args=only_keep_pass=true'

    // Match DV + Strelka2 combination step
    combine_dv_strelka_enable = false
    norm_combined_enable      = false

    // Keep DeepVariant-only normalization too
    norm_dv_only_enable = false

    strict_variant_requirements = false
}

process {
    withName: 'DEEPVARIANT_RUNDEEPVARIANT' {
        // This controls --num_shards=${task.cpus}
        cpus   = 64
        memory = '120 GB'
    }

    withName: 'STRELKA_GERMLINE' {
        cpus   = 8
        memory = '40 GB'

        // Match pipeline_nextflow.txt:
        // configureStrelkaGermlineWorkflow.py --exome --callContinuousVf chrM
        ext.args = '--exome --callContinuousVf chrM'
    }

    withName: 'BCFTOOLS_CONCAT_VCF' {
        // Match: bcftools concat -a -D
        // Use compressed output + index because downstream BCFTOOLS_NORM_COMBINED
        // expects a VCF and index pair.
        ext.args = '-a -D -Oz --write-index=tbi'
    }

    withName: 'BCFTOOLS_NORM_COMBINED' {
        // Match: bcftools norm -m +any
        ext.args = '-m +any -Oz --write-index=tbi'
    }

    withName: 'BCFTOOLS_NORM_DVONLY' {
        // Match DeepVariant-only normalization:
        // bcftools norm -m +any
        ext.args = '-m +any -Oz --write-index=tbi'
    }
}
